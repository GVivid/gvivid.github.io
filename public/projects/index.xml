 (range &lt;= 200) return 20;&#xA;&#x9;&#x9;&#x9;&#x9;if (range &lt;= 500) return 50;&#xA;&#x9;&#x9;&#x9;&#x9;if (range &lt;= 2000) return 200;&#xA;&#x9;&#x9;&#x9;&#x9;return 500;&#xA;&#x9;&#x9;&#x9;}&#xA;&#xA;&#x9;&#x9;&#x9;function getBoundedLinePoints(Fn) {&#xA;&#x9;&#x9;&#x9;&#x9;let qStart = 0;&#xA;&#x9;&#x9;&#x9;&#x9;let pStart = Fn(qStart);&#xA;&#x9;&#x9;&#x9;&#x9;let qEnd = maxQ;&#xA;&#x9;&#x9;&#x9;&#x9;let pEnd = Fn(qEnd);&#xA;&#xA;&#x9;&#x9;&#x9;&#x9;if (pStart &lt; 0 &amp;&amp; pEnd &gt; 0 &amp;&amp; pStart !== pEnd) {&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;qStart = (0 - pStart) / ((pEnd - pStart) / (maxQ - 0));&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;pStart = 0;&#xA;&#x9;&#x9;&#x9;&#x9;} else if (pStart &gt; 0 &amp;&amp; pEnd &lt; 0 &amp;&amp; pStart !== pEnd) {&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;qEnd = (0 - pStart) / ((pEnd - pStart) / (maxQ - 0));&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;pEnd = 0;&#xA;&#x9;&#x9;&#x9;&#x9;}&#xA;&#xA;&#x9;&#x9;&#x9;&#x9;if (pStart &gt; maxP &amp;&amp; pEnd &lt; maxP &amp;&amp; pStart !== pEnd) {&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;qStart = (maxP - pStart) / ((pEnd - pStart) / (maxQ - 0));&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;pStart = maxP;&#xA;&#x9;&#x9;&#x9;&#x9;} else if (pStart &lt; maxP &amp;&amp; pEnd &gt; maxP &amp;&amp; pStart !== pEnd) {&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;qEnd = (maxP - pStart) / ((pEnd - pStart) / (maxQ - 0));&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;pEnd = maxP;&#xA;&#x9;&#x9;&#x9;&#x9;}&#xA;&#xA;&#x9;&#x9;&#x9;&#x9;if (pStart &lt; 0 &amp;&amp; pEnd &lt; 0) return null;&#xA;&#x9;&#x9;&#x9;&#x9;return {x1: toScreenX(qStart), y1: toScreenY(pStart), x2: toScreenX(qEnd), y2: toScreenY(pEnd)};&#xA;&#x9;&#x9;&#x9;}&#xA;&#xA;&#x9;&#x9;&#x9;function drawBoundedLine(Fn, color, width, dashed = false) {&#xA;&#x9;&#x9;&#x9;&#x9;const pts = getBoundedLinePoints(Fn);&#xA;&#x9;&#x9;&#x9;&#x9;if (!pts) return;&#xA;&#xA;&#x9;&#x9;&#x9;&#x9;ctx.strokeStyle = color;&#xA;&#x9;&#x9;&#x9;&#x9;ctx.lineWidth = width;&#xA;&#x9;&#x9;&#x9;&#x9;if (dashed) ctx.setLineDash([3, 4]);&#xA;&#xA;&#