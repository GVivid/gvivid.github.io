#x9;&#x9;&#x9;if (type !== &#39;lumpsum&#39; &amp;&amp; Qact !== Qe) {&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;ctx.fillStyle = direction === &#39;tax&#39; ? &#39;rgba(207, 102, 121, 0.35)&#39; : &#39;rgba(102, 187, 106, 0.3)&#39;;&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;ctx.beginPath();&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;if (direction === &#39;tax&#39; &amp;&amp; Qact &lt; Qe) {&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;ctx.moveTo(toScreenX(Qact), toScreenY(Math.min(maxP, Math.max(0, Pd))));&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;ctx.lineTo(toScreenX(Qe), toScreenY(Math.min(maxP, Math.max(0, Pe))));&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;ctx.lineTo(toScreenX(Qact), toScreenY(Math.min(maxP, Math.max(0, Ps))));&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;} else if (direction === &#39;subsidy&#39; &amp;&amp; Qact &gt; Qe) {&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;ctx.moveTo(toScreenX(Qe), toScreenY(Math.min(maxP, Math.max(0, Pe))));&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;ctx.lineTo(toScreenX(Qact), toScreenY(Math.min(maxP, Math.max(0, Ps))));&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;ctx.lineTo(toScreenX(Qact), toScreenY(Math.min(maxP, Math.max(0, Pd))));&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;}&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;ctx.closePath(); ctx.fill();&#xA;&#x9;&#x9;&#x9;&#x9;}&#xA;&#xA;&#x9;&#x9;&#x9;&#x9;if (type !== &#39;lumpsum&#39; &amp;&amp; rate &gt; 0) {&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;if (FnDEff !== FnD) drawBoundedLine(FnDEff, &#39;#29b6f6aa&#39;, 1.5, true);&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;if (FnSEff !== FnS) drawBoundedLine(FnSEff, &#39;#66bb6aaa&#39;, 1.5, true);&#xA;&#x9;&#x9;&#x9;&#x9;}&#xA;&#xA;&#x9;&#x9;&#x9;&#x9;drawBoundedLine(FnD, &#39;#29b6f6&#39;, 3, false);&#xA;&#x9;&#x9;&#x9;&#x9;drawBoundedLine(FnS, &#39;#66bb6a&#39;, 3, false);&#xA;&#xA;&#x9;&#x9;&#x9;&#x9;ctx.strokeStyle = &#39;#aaaaaa&#39;; ctx.lineWidth = 1.2; ctx.setLineDash([4, 4]);&#xA;&#x9;&#x9;&#x9;&#x9;if (type !== &#39;lumpsum&#39;) {&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;if (Pd &lt;= maxP &amp;&amp; Pd &gt;= 0) {ctx.beginPath(); ctx.moveTo(toScreenX(0), toScreenY(Pd)); ctx.lineTo(toScreenX(Qact), toScreenY(Pd)); ctx.stroke();}&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;if (Ps &lt;= maxP &amp;&amp; Ps &gt;= 0) {ctx.beginPath(); ctx.moveTo(toScreenX(0), toScreenY(Ps)); ctx.lineTo(toScreenX(Qact), toScreenY(Ps)); ctx.stroke();}&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;if (Qact &lt;= maxQ &amp;&amp; Qact &gt;= 0) {ctx.beginPath(); ctx.moveTo(toScreenX(Qact), toScreenY(0)); ctx.lineTo(toScreenX(Qact), toScreenY(Math.min(maxP, Math.max(0, Math.max(Pd, Ps))))); ctx.stroke();}&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;ctx.setLineDash([]);&#xA;&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;ctx.strokeStyle = &#39;#ffffff&#39;; ctx.lineWidth = 2;&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;ctx.beginPath(); ctx.moveTo(toScreenX(Qact), toScreenY(Math.min(maxP, Math.max(0, Pd)))); ctx.lineTo(toScreenX(Qact), toScreenY(Math.min(maxP, Math.max(0, Ps)))); ctx.stroke();&#xA;&#x9;&#x9;&#x9;&#x9;} else {&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;if (Pe &lt;= maxP &amp;&amp; Pe &gt;= 0) {ctx.beginPath(); ctx.moveTo(toScreenX(0), toScreenY(Pe)); ctx.lineTo(toScreenX(Qe), toScreenY(Pe)); ctx.stroke();}&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;if (Qe &lt;= maxQ &amp;&amp; Qe &gt;= 0) {ctx.beginPath(); ctx.moveTo(toScreenX(Qe), toScreenY(0)); ctx.lineTo(toScreenX(Qe), toScreenY(Math.min(maxP, Math.max(0, Pe)))); ctx.stroke();}&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;ctx.setLineDash([]);&#xA;&#x9;&#x9;&#x9;&#x9;}&#xA;&#xA;&#x9;&#x9;&#x9;&#x9;ctx.strokeStyle = &#39;#ffffff&#39;; ctx.lineWidth = 2;&#xA;&#x9;&#x9;&#x9;&#x9;ctx.beginPath(); ctx.moveTo(padding.left, padding.top); ctx.lineTo(padding.left, canvas.height - padding.bottom); ctx.lineTo(canvas.width - padding.right, canvas.height - padding.bottom); ctx.stroke();&#xA;&#xA;&#x9;&#x9;&#x9;&#x9;ctx.fillStyle = &#39;#ffffff&#39;;&#xA;&#x9;&#x9;&#x9;&#x9;if (!isNaN(Pe) &amp;&amp; Qe &lt;= maxQ &amp;&amp; Qe &gt;= 0 &amp;&amp; Pe &lt;= maxP &amp;&amp; Pe &gt;= 0) {ctx.beginPath(); ctx.arc(toScreenX(Qe), toScreenY(Pe), 5, 0, 2 * Math.PI); ctx.fill();}&#xA;&#x9;&#x9;&#x9;}&#xA;&#xA;&#x9;&#x9;&#x9;[inputs.demandA, inputs.demandB, inputs.supplyC, inputs.supplyD, inputs.direction, inputs.side, inputs.type, inputs.axisMode, inputs.customMaxQ, inputs.customMaxP].forEach(el =&gt; {&#xA;&#x9;&#x9;&#x9;&#x9;el.addEventListener(&#39;input&#39;, update);&#xA;&#x9;&#x9;&#x9;});&#xA;&#xA;&#x9;&#x9;&#x9;update();&#xA;&#x9;&#x9;})();&#xA;&#x9;&lt;/script&gt;&#xA;&lt;/div&gt;&#xA;&lt;/p&gt;</description>
